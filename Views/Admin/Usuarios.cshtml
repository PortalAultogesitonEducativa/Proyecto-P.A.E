@model List<ProyectoPAE.Models.Usuario>

<div class="container mt-4">
    <h2><i class="bi bi-people-fill text-success me-2"></i>Gestión de Usuarios</h2>
    <hr />

    <form method="get" asp-action="Usuarios" class="row g-3 mb-4">
        <div class="col-md-10">
            <input type="text" name="buscar" class="form-control" placeholder="Buscar por nombre o rol...">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-success w-100">Buscar</button>
        </div>
    </form>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-secondary">Lista de Usuarios</h3>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalRegistroEstudiante">
            <i class="bi bi-person-plus-fill"></i> Registrar Estudiante
        </button>
    </div>

    <div class="modal fade" id="modalRegistroEstudiante" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="@Url.Action("RegistrarEstudiante", "Admin")" method="post">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title" id="modalLabel">Nuevo Registro de Estudiante</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Nombres Completos</label>
                            <input type="text" name="NOMBRES" class="form-control" placeholder="Ej: Juan" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Apellidos</label>
                            <input type="text" name="APELLIDOS" class="form-control" placeholder="Ej: Pérez" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Correo Institucional</label>
                            <input type="email" name="CORREO_ELECTRONICO" class="form-control" placeholder="ejemplo@estudiantil.edu.co" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Asignar a Curso (Grado)</label>
                            <select name="CursoSeleccionado" class="form-select" required>
                                <option value="" disabled selected>Seleccione un grado...</option>
                                <option value="6">Grado 6°</option>
                                <option value="7">Grado 7°</option>
                                <option value="8">Grado 8°</option>
                                <option value="9">Grado 9°</option>
                                <option value="10">Grado 10°</option>
                                <option value="11">Grado 11°</option>
                            </select>
                            <small class="text-muted">Se registrará automáticamente en la tabla MATRICULA.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Contraseña Temporal</label>
                            <input type="password" name="CONTRASEÑA" class="form-control" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar Estudiante</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Rol</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.NOMBRES @user.APELLIDOS</td>
                    <td>@user.CORREO_ELECTRONICO</td>
                    <td><span class="badge bg-info text-dark">@user.ROL</span></td>
                    <td>@(user.ACTIVO ? "Activo" : "Inactivo")</td>
                    <td>
                        @if (user.ROL == "estudiante")
                        {
                            <form asp-action="RenovarMatricula" method="post" style="display:inline;">
                                <input type="hidden" name="idEstudiante" value="@user.ID_Usuario" />
                                <button type="submit" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-arrow-repeat"></i> Renovar 2026
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
