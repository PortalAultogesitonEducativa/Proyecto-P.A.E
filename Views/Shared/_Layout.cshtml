<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAE</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light border-bottom box-shadow mb-3" style="background-color: #fdf8f3;">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="PAE Logo" style="height: 45px;" class="me-2">
                    <span class="fw-bold" style="color: #0d2a4a; font-size: 1.2rem;">Portal de Autogestión Educativa</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav flex-grow-1 justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2" asp-controller="Home" asp-action="Nosotros">Nosotros</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2" asp-controller="Home" asp-action="Cursos">Módulos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark px-3" asp-controller="Home" asp-action="Blog">Blog</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2" asp-controller="Home" asp-action="Contacto">Contacto</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center">
                        @if (Context.Session.GetString("NombreUsuario") != null)
                        {
                            <div class="dropdown d-flex align-items-center">
                                <a class="nav-link dropdown-toggle text-dark fw-bold d-flex align-items-center me-3"
                                       href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1" style="font-size: 1.2rem;"></i>
                                    <span>@Context.Session.GetString("NombreUsuario")</span>
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Home" asp-action="Perfil">
                                            <i class="bi bi-person me-2"></i>Mi Perfil
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Login" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Login" asp-action="Index"
                                   class="btn text-white px-4 fw-bold"
                                   style="background-color: #e67e22; border-radius: 8px;">
                                Iniciar Sesión
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5" style="background-color: #fdf8f3; padding: 40px 0;">
        <div class="container">
            <div class="row text-dark">
                <div class="col-md-4">
                    <h5 class="fw-bold">PAE</h5>
                    <p class="small">Portal de Autogestión Educativa.</p>
                </div>
                <div class="col-md-4">
                    <h5 class="fw-bold">Enlaces</h5>
                    <ul class="list-unstyled small">
                        <li><a asp-action="Index" class="text-decoration-none text-muted">Inicio</a></li>
                        <li><a asp-action="Nosotros" class="text-decoration-none text-muted">Nosotros</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5 class="fw-bold">Contacto</h5>
                    <p class="small">info@pae.edu.co</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>